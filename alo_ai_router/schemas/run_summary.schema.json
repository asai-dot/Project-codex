{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "run_summary v0.1",
  "type": "object",
  "required": ["run_id", "request_id", "executor", "outcome", "started_at", "ended_at", "self_grade", "caveats"],
  "properties": {
    "run_id": {"type": "string"},
    "request_id": {"type": "string"},
    "executor": {"type": "string"},
    "model": {"type": ["string", "null"]},
    "model_family": {"type": ["string", "null"]},
    "outcome": {"enum": ["candidate_produced", "need_more", "deferred", "failed"]},
    "stop_reason": {"type": ["string", "null"]},
    "started_at": {"type": "string"},
    "ended_at": {"type": "string"},
    "input_count": {"type": "integer"},
    "output_count": {"type": "integer"},
    "mutation_power_granted": {"enum": ["none", "draft_write"]},
    "self_grade": {"enum": ["A", "B", "C", "D"]},
    "honest_report": {"type": "object"},
    "caveats": {"type": "array", "items": {"type": "string"}},
    "subagents_used": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "why"],
        "properties": {
          "type": {"enum": ["Explore", "Plan", "general-purpose", "claude-code-guide", "claude"]},
          "why": {"type": "string"}
        }
      }
    }
  }
}
