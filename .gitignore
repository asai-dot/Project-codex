# Local config with real Box folder_id / canonical paths — never commit.
config/gakuyo.env

# Spool (state/results/logs) lives under $HOME/.alo_spool by default; if a runner
# points SPOOL_ROOT inside the repo, keep its artifacts out of git.
.alo_spool/
/spool/
*.reject

# Selftest scratch
.selftest/
__pycache__/
*.pyc

# A1 実相談検索観測ベースライン: PII/大容量を除外し、安全な集計のみコミット
/build/search_bench/*
!/build/search_bench/terms_554_snapshot.json
!/build/search_bench/a1_consultation_queries_report_safe.csv
!/build/search_bench/a1_summary.json
!/build/search_bench/shiseido_standard_books_master.csv
!/build/search_bench/shiseido_shelf_standard_flag_candidates.csv
!/build/search_bench/shiseido_match_summary.json
