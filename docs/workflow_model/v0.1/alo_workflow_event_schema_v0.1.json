{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ALO Workflow Event Envelope",
  "description": "浅井法律事務所の業務上の観測事実・状態遷移・作業・文書・判断・財務を、原ソースへの参照付きで記録するための暫定スキーマ。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "event_type",
    "occurred_at",
    "captured_at",
    "source",
    "matter_ref",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "alo-workflow-event-0.1"
    },
    "event_id": {
      "type": "string",
      "pattern": "^alo:event:[A-Za-z0-9._:-]+$"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "inquiry_received",
        "consultation_candidate_created",
        "safe_contact_confirmed",
        "party_identified",
        "conflict_check_requested",
        "conflict_check_completed",
        "triage_completed",
        "consultation_date_options_sent",
        "consultation_scheduled",
        "consultation_rescheduled",
        "consultation_cancelled",
        "document_requested",
        "document_received",
        "document_classified",
        "consultation_started",
        "consultation_completed",
        "advice_recorded",
        "followup_question_received",
        "post_consult_decision_recorded",
        "quote_requested",
        "proposal_created",
        "proposal_approved_internal",
        "proposal_sent",
        "proposal_followup_due",
        "proposal_revision_requested",
        "proposal_accepted",
        "proposal_rejected",
        "engagement_signed",
        "retainer_invoice_sent",
        "payment_acknowledged_external",
        "payment_received",
        "consultation_converted_to_matter",
        "matter_workspace_created",
        "matter_plan_approved",
        "inbound_message_received",
        "call_completed",
        "meeting_held",
        "postal_item_received",
        "work_item_created",
        "work_item_started",
        "work_item_waiting",
        "work_item_completed",
        "work_session_recorded",
        "draft_created",
        "internal_review_requested",
        "internal_review_completed",
        "client_review_requested",
        "client_approval_received",
        "deliverable_sent",
        "court_filing_submitted",
        "delivery_acknowledged",
        "deadline_created",
        "deadline_changed",
        "deadline_completed",
        "invoice_created",
        "invoice_sent",
        "invoice_overdue",
        "trust_deposit_received",
        "expense_recorded",
        "trust_refund_sent",
        "scope_change_detected",
        "outcome_reached",
        "closing_authorized",
        "financial_reconciliation_completed",
        "originals_returned",
        "closing_report_sent",
        "closing_ack_received",
        "matter_closed",
        "knowledge_summary_promoted",
        "link_correction_recorded",
        "incident_reported",
        "automation_failure_detected"
      ]
    },
    "event_category": {
      "type": "string"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "effective_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "matter_ref": {
      "$ref": "#/$defs/RecordRef"
    },
    "consultation_ref": {
      "oneOf": [
        {
          "$ref": "#/$defs/RecordRef"
        },
        {
          "type": "null"
        }
      ]
    },
    "actor": {
      "oneOf": [
        {
          "$ref": "#/$defs/ActorRef"
        },
        {
          "type": "null"
        }
      ]
    },
    "counterparties": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ActorRef"
      }
    },
    "source": {
      "$ref": "#/$defs/SourceRef"
    },
    "summary": {
      "type": "string",
      "maxLength": 4000
    },
    "state_transition": {
      "oneOf": [
        {
          "$ref": "#/$defs/StateTransition"
        },
        {
          "type": "null"
        }
      ]
    },
    "work_item": {
      "oneOf": [
        {
          "$ref": "#/$defs/WorkItem"
        },
        {
          "type": "null"
        }
      ]
    },
    "document_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/DocumentRef"
      }
    },
    "decision": {
      "oneOf": [
        {
          "$ref": "#/$defs/DecisionRecord"
        },
        {
          "type": "null"
        }
      ]
    },
    "finance": {
      "oneOf": [
        {
          "$ref": "#/$defs/FinanceRecord"
        },
        {
          "type": "null"
        }
      ]
    },
    "deadlines": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/DeadlineRef"
      }
    },
    "extracted_facts": {
      "type": "object",
      "additionalProperties": true
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "review": {
      "$ref": "#/$defs/HumanReview"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "invalidates_event_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "RecordRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system",
        "object_type",
        "record_id"
      ],
      "properties": {
        "system": {
          "type": "string"
        },
        "object_type": {
          "type": "string"
        },
        "record_id": {
          "type": "string"
        },
        "display_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "uri": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ActorRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor_type",
        "actor_id"
      ],
      "properties": {
        "actor_type": {
          "enum": [
            "staff",
            "lawyer",
            "client",
            "prospect",
            "opponent",
            "court",
            "vendor",
            "insurer",
            "public_body",
            "system",
            "unknown"
          ]
        },
        "actor_id": {
          "type": "string"
        },
        "role": {
          "type": [
            "string",
            "null"
          ]
        },
        "display_name": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "SourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system",
        "native_id",
        "source_kind"
      ],
      "properties": {
        "system": {
          "type": "string"
        },
        "native_id": {
          "type": "string"
        },
        "source_kind": {
          "enum": [
            "email",
            "call",
            "sms",
            "meeting",
            "calendar",
            "box_file",
            "box_event",
            "salesforce_record",
            "postal",
            "fax",
            "court_portal",
            "invoice",
            "bank_transaction",
            "manual_statement",
            "system_log"
          ]
        },
        "thread_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "url": {
          "type": [
            "string",
            "null"
          ]
        },
        "content_hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_timestamp": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "StateTransition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_machine",
        "to_state",
        "basis"
      ],
      "properties": {
        "state_machine": {
          "enum": [
            "consultation",
            "matter",
            "work_item",
            "document",
            "finance",
            "deadline",
            "engagement"
          ]
        },
        "from_state": {
          "type": [
            "string",
            "null"
          ]
        },
        "to_state": {
          "type": "string"
        },
        "basis": {
          "enum": [
            "observed",
            "declared",
            "rule_derived",
            "human_decision"
          ]
        },
        "reason_code": {
          "type": [
            "string",
            "null"
          ]
        },
        "reason_text": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "WorkItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "work_item_id",
        "title",
        "status",
        "owner_ref"
      ],
      "properties": {
        "work_item_id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "status": {
          "enum": [
            "open",
            "in_progress",
            "waiting",
            "blocked",
            "review",
            "complete",
            "cancelled"
          ]
        },
        "owner_ref": {
          "$ref": "#/$defs/RecordRef"
        },
        "due_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "waiting_on": {
          "type": [
            "string",
            "null"
          ]
        },
        "completion_definition": {
          "type": [
            "string",
            "null"
          ]
        },
        "completion_evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "parent_work_item_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "DocumentRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document_id",
        "system",
        "document_type",
        "lifecycle_state"
      ],
      "properties": {
        "document_id": {
          "type": "string"
        },
        "system": {
          "type": "string"
        },
        "box_file_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "box_version_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "document_type": {
          "type": "string"
        },
        "direction": {
          "enum": [
            "inbound",
            "outbound",
            "internal",
            "mixed"
          ]
        },
        "lifecycle_state": {
          "enum": [
            "received",
            "classified",
            "working_draft",
            "internal_review",
            "client_review",
            "approved",
            "sent",
            "filed",
            "accepted",
            "superseded",
            "archived",
            "quarantine"
          ]
        },
        "package_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "content_hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "recipient_party_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "DecisionRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_type",
        "outcome",
        "decided_by",
        "decided_at"
      ],
      "properties": {
        "decision_type": {
          "type": "string"
        },
        "outcome": {
          "type": "string"
        },
        "decided_by": {
          "$ref": "#/$defs/ActorRef"
        },
        "decided_at": {
          "type": "string",
          "format": "date-time"
        },
        "rationale": {
          "type": [
            "string",
            "null"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "policy_version": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "FinanceRecord": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "finance_event_type": {
          "enum": [
            "quote",
            "invoice",
            "payment",
            "trust_deposit",
            "expense",
            "refund",
            "writeoff",
            "reconciliation"
          ]
        },
        "currency": {
          "type": "string",
          "default": "JPY"
        },
        "amount": {
          "type": [
            "number",
            "null"
          ]
        },
        "fee_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "client_party_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "payer_party_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "invoice_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "external_reference": {
          "type": [
            "string",
            "null"
          ]
        },
        "due_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "balance_after": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    },
    "DeadlineRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deadline_id",
        "deadline_type",
        "due_at"
      ],
      "properties": {
        "deadline_id": {
          "type": "string"
        },
        "deadline_type": {
          "enum": [
            "statutory",
            "court_ordered",
            "counterparty",
            "client",
            "internal_target",
            "payment",
            "followup"
          ]
        },
        "due_at": {
          "type": "string",
          "format": "date-time"
        },
        "base_date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "basis_document_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "owner_ref": {
          "oneOf": [
            {
              "$ref": "#/$defs/RecordRef"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "HumanReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "enum": [
            "not_required",
            "pending",
            "approved",
            "corrected",
            "rejected"
          ]
        },
        "reviewer_ref": {
          "oneOf": [
            {
              "$ref": "#/$defs/RecordRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "reviewed_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "comment": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "Provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ingest_run_id",
        "extractor_version",
        "source_refs"
      ],
      "properties": {
        "ingest_run_id": {
          "type": "string"
        },
        "extractor_version": {
          "type": "string"
        },
        "model_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "prompt_or_policy_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "payload_hash": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}