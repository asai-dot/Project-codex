# gakuyo.env — config for scripts/gakuyo_reconcile.sh
# Copy to config/gakuyo.env (gitignored) and edit. Source it via --config.
#
#   cp config/gakuyo.env.example config/gakuyo.env
#   scripts/gakuyo_reconcile.sh --config config/gakuyo.env

# --- claude ----------------------------------------------------------------
# Path to the claude CLI. Override with a mock for tests (see selftest).
CLAUDE_BIN="claude"
# Output capture format from `claude -p`. "text" is simplest; the orchestrator
# strips fences + validates JSON regardless.
CLAUDE_OUTPUT_FORMAT="text"
# Extra args passed verbatim to every `claude -p` (e.g. --model ...).
CLAUDE_EXTRA_ARGS=""
# Tools the per-unit model call may use. EMPTY = none (slices are embedded in the
# prompt, so the model needs no tools — tightest privilege). Only set this if you
# switch to a slicer that makes the model read files itself, e.g. "Read".
ALLOWED_TOOLS=""

# --- spool / state ---------------------------------------------------------
SPOOL_ROOT="$HOME/.alo_spool/gakuyo"
# INPUT_DIR/RESULTS_DIR/LOG_DIR/STATE_FILE default under SPOOL_ROOT; override if needed.
# UNITS_MANIFEST default: $SPOOL_ROOT/units.txt  (one unit id per line; # comments ok)
# UNITS_MANIFEST="$SPOOL_ROOT/units.txt"

# --- inputs (raw, never overwritten) ---------------------------------------
# GEMINI_INDEX="$SPOOL_ROOT/inputs/gemini_index.txt"
# PADDLE_INDEX="$SPOOL_ROOT/inputs/paddle_index.txt"
# JSON1_TXT="$SPOOL_ROOT/inputs/json1.txt"

# --- slicer (granularity knob — head's decision) ---------------------------
# Default slicer supports "### <unit-id>" markers in each input file.
# SLICER="$PWD/scripts/slice_unit.sh"

# --- Box canonical publish (head supplies folder_id / path at dispatch) -----
PUBLISH=1
# drive (Box Drive synced folder) | mcp-bridge (Box MCP upload) | none
BOX_MODE="drive"
# For BOX_MODE=drive:
BOX_CANONICAL_DIR=""        # e.g. "$HOME/Library/CloudStorage/Box-Box/ALO/gakuyo/canonical"
# For BOX_MODE=mcp-bridge:
BOX_CANONICAL_FOLDER_ID=""  # <<< head supplies the Box folder_id here
BOX_UPLOAD_TOOL=""          # the Box MCP upload tool name, e.g. mcp__<server>__upload_file
